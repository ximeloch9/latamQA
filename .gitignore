# Maven binario (herramienta externa)
apache-maven-3.8.8/

# Compilados y empaquetados de Java/Maven
**/target/
*.class
*.bluej
*.pkg
*.ctxt
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Bases de datos SQLite locales y temporales
*.db
*.db-journal

# Archivos de registro / Logs
*.log

# Archivos de reporte locales generados
**/output/*.csv

# Copias de seguridad temporales fuera de Git (por si acaso)
LatamQAPOC_backup/

# Configuraciones de Entornos de Desarrollo (IDEs)
.idea/
*.iml
.classpath
.project
.settings/
.vscode/
.DS_Store

# NO ignorar config.properties en el subproyecto (necesario para pruebas)
!**/src/main/resources/config.properties
